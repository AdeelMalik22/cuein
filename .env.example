# Copy this file to .env for local development, then replace the example
# values. Environment variables supplied by the host take precedence over .env.

# PostgreSQL (required)
POSTGRES_DB=cuein
POSTGRES_USER=cuein
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Django
DJANGO_ENV=development
DJANGO_DEBUG=true
# Production only: set a long, unique value through your deployment secret store.
# DJANGO_SECRET_KEY=replace-with-a-long-unique-secret
# DJANGO_ALLOWED_HOSTS=app.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com
# DJANGO_BEHIND_PROXY=true
# DJANGO_HSTS_INCLUDE_SUBDOMAINS=false
# DJANGO_HSTS_PRELOAD=false
# DJANGO_LOG_FORMAT=json
# DJANGO_LOG_LEVEL=INFO

# Redis or Valkey. Valkey speaks the Redis protocol, so the same URL format
# works for Celery and Django's cache. Use rediss:// for a TLS endpoint.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
# CELERY_TASK_ALWAYS_EAGER=false

# Email. Development uses Django's console backend by default; uncomment and
# configure these values when sending email through SMTP.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=Cuein <no-reply@example.com>
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-smtp-user
# EMAIL_HOST_PASSWORD=your-smtp-app-password
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_TIMEOUT=10
# EMAIL_VERIFICATION_TIMEOUT=86400
# EMAIL_VERIFICATION_RESEND_COOLDOWN=60
# PASSWORD_RESET_TIMEOUT=900
# PASSWORD_RESET_RESEND_COOLDOWN=60

# Optional Cloudflare Turnstile challenge after repeated failed logins.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# TURNSTILE_TIMEOUT=5
